ARK_API_KEY=your_real_ark_api_key
# 可选：.xls 在 xlrd 失败时用 LibreOffice 无界面转换；填写 soffice 可执行文件绝对路径
# LAWLAW_SOFFICE=/Applications/LibreOffice.app/Contents/MacOS/soffice
# 方舟控制台「推理接入点」ID（ep- 开头），多模态向量模型
EMBEDDING_ENDPOINT_ID=ep-your-embedding-endpoint-id
# 兼容旧配置；未设置 EMBEDDING_ENDPOINT_ID 时仍可读此项
# EMBEDDING_MODEL_ID=doubao-embedding-vision-251215
CHAT_VISION_ENDPOINT_ID=ep-your-chat-vision-endpoint-id
# 兼容旧配置
# CHAT_VISION_MODEL_ID=doubao-1.5-vision-pro-250328
